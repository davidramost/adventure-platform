# =============================================
# ENVIRONMENT VARIABLES (Render / Local)
# =============================================
# Copiar este archivo como .env y reemplazar los valores de placeholder

SPRING_PROFILES_ACTIVE=prod          # Perfil: prod (TiDB Cloud) o dev (MySQL local)
DB_HOST=gateway01.eu-central-1.prod.aws.tidbcloud.com   ← Cambia esto si es necesario
DB_PORT=4000                         ← Puerto TiDB MySQL compatible  
DB_NAME=rutas_app                    ← Nombre de tu BD en TiDB Cloud
DB_USER=<TU_USUARIO_AQUI>            # Ej: 2nfTyrNJinYxZ9D.root (sin @)
DB_PASSWORD=<TU_CONTRASEÑA_AQUI>     # La contraseña real

# JWT Configuration  
JWT_SECRET=TuSecretoMuyLargoDeAlMenos32CaracteresParaJwtToken!!  ← Generar un nuevo para producción
JWT_EXPIRATION=86400000              # Expiración en ms (1 día)
